# KDP_MASTER - Variables de Entorno
# Copia este archivo como .env y completa tus datos

# API de Google Gemini (obtén gratis en: https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=

# Configuración del modelo LLM
LLM_MODEL=gemini-2.0-flash-exp
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048

# Configuración de Monitoreo Automático de Canales
MONITOR_INTERVAL_MINUTES=60
MAX_VIDEOS_PER_CHECK=10
AUTO_MONITOR_ENABLED=true

# Opcional: Otras APIs
AMAZON_API_KEY=
AFFINITY_LICENSE=